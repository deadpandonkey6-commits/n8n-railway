# n8n environment variables for Railway

# Database configuration
DB_TYPE=postgres
DB_POSTGRESDB=your_postgres_db_name
DB_POSTGRES_HOST=your_postgres_host
DB_POSTGRES_PORT=5432
DB_POSTGRES_USERNAME=your_postgres_username
DB_POSTGRES_PASSWORD=your_postgres_password

# n8n API settings
N8N_API_URL=https://your-n8n-url.com
N8N_ENCRYPTION_KEY=your_encryption_key

# SMTP Email configuration
N8N_SMTP_HOST=your_smtp_host
N8N_SMTP_PORT=587
N8N_SMTP_USER=your_smtp_user
N8N_SMTP_PASS=your_smtp_password
N8N_SMTP_SENDER_EMAIL=your_sender_email

# Other required variables
N8N_WEBHOOK_URL=https://your-n8n-url.com/webhook
NODE_ENV=production