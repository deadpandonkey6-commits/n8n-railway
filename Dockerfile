FROM n8nio/n8n:latest\n\n# Set environment variables for production-ready configuration\nENV N8N_HOST=your-host.com\nENV N8N_PORT=5678\nENV N8N_PROTOCOL=https\nENV DB_TYPE=postgresdb\nENV DB_POSTGRESDB_SERVER=your-db-server\nENV DB_POSTGRESDB_PORT=5432\nENV DB_POSTGRESDB_DATABASE=your-database\nENV DB_POSTGRESDB_USER=your-user\nENV DB_POSTGRESDB_PASSWORD=your-password\nENV N8N_EDITOR_BASE_URL=https://your-editor-url.com\n\n# Expose the ports\nEXPOSE 5678